<?xml version="1.0"?>
<robot name="simple_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

        <xacro:include filename="$(find ros2_control_car)/model/gazebo.xacro"/>

        <xacro:include filename="$(find ros2_control_car)/model/wheels/omni_wheel.urdf.xacro"/>

        <link name="base_link">
                <visual>
                        <geometry>
                        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
                        </geometry>
                        <origin xyz="0 0 ${chassis_offset}" rpy="0 0 0"/>
                        <material name="red"/>
                </visual>

                <collision>
                        <geometry>
                        <box size="0.3 0.25 0.05"/>
                        </geometry>
                        <origin xyz="0 0 ${chassis_offset}" rpy="0 0 0"/>
                </collision>

                <xacro:chassis_inertia />
        </link>




        <!-- LINKS ET JOINTS DES ROUES -->



        <xacro:omni_wheel
                prefix="lf"
                parent="base_link"
                xyz="${chassis_length/2 + wheel_width} 0 ${r}"
                rpy="0 0 ${-pi/2}"
        />

        <xacro:omni_wheel
                prefix="rf"
                parent="base_link"
                xyz="0 ${-chassis_width/2 - wheel_width} ${r}"
                rpy="0 0 ${pi}"
        />

        <xacro:omni_wheel
                prefix="lb"
                parent="base_link"
                xyz="0 ${chassis_width/2 + wheel_width} ${r}"
                rpy="0 0 0"
        />

        <xacro:omni_wheel
                prefix="rb"
                parent="base_link"
                xyz="${-chassis_length/2 - wheel_width} 0 ${r}"
                rpy="0 0 ${pi/2}"
        />



        <!--  ROBOTIC ARM LINKS-->


        <link name="fixed_arm">
                <visual>
                        <geometry>
                                <box size="${arm_length} ${arm_width} ${arm_height}"/>
                        </geometry>
                        <origin xyz="0 0 ${arm_height/2}" rpy="0 0 0"/>
                        <material name="blue"/>
                </visual>
                

                <collision>
                        <geometry>
                                <box size="${arm_length} ${arm_width} ${arm_height}"/>
                        </geometry>
                        <origin xyz="0 0 ${arm_height/2}" rpy="0 0 0"/>
                        <material name="blue"/>
                </collision>

                <xacro:arm_inertia/>
        </link>

        <link name="first_moving_arm">
                <visual>
                        <geometry>
                                <box size="${arm_length} ${arm_width} ${arm_height*2}"/>
                        </geometry>
                        <origin xyz="0 0 ${arm_height}" rpy="0 0 0"/>
                        <material name="green"/>
                </visual>
                

                <collision>
                        <geometry>
                                <box size="${arm_length} ${arm_width} ${arm_height*2}"/>
                        </geometry>
                        <origin xyz="0 0 ${arm_height}" rpy="0 0 0"/>
                        <material name="green"/>
                </collision>

                <xacro:arm_inertia/>
        </link>

        <link name="second_moving_arm">
                <visual>
                        <geometry>
                                <box size="${arm_length} ${arm_width} ${arm_height/2}"/>
                        </geometry>
                        <origin xyz="0 0 ${arm_height/4}" rpy="0 0 0"/>
                        <material name="yellow"/>
                </visual>
                

                <collision>
                        <geometry>
                                <box size="${arm_length} ${arm_width} ${arm_height/2}"/>
                        </geometry>
                        <origin xyz="0 0 ${arm_height/4}" rpy="0 0 0"/>
                        <material name="yellow"/>
                </collision>

                <xacro:arm_inertia/>
        </link>

        <!-- ROBOTIC ARM JOINTS-->

        <joint name="fixed_arm_joint" type="fixed">
                <parent link="base_link" />
                <child link="fixed_arm" />
                <origin xyz="0 0 ${chassis_offset + chassis_height/2}" rpy="0 0 0"/>
        </joint>

        <joint name="first_moving_arm_joint" type="revolute">
                <parent link="fixed_arm" />
                <child link="first_moving_arm" />
                <origin xyz="0 ${arm_width} ${3*arm_height/4}" rpy="0 0 0"/>
                <axis xyz="0 1 0"/>
                <limit effort="5000" velocity="10" lower="${-pi}" upper="${pi}"/>
                <dynamics damping="1.0" friction="1.0"/>
        </joint>

        <joint name="second_moving_arm_joint" type="revolute">
                <parent link="first_moving_arm" />
                <child link="second_moving_arm" />
                <origin xyz="0 -${arm_width} ${15*arm_height/8}" rpy="0 0 0"/>
                <axis xyz="0 1 0"/>
                <limit effort="5000" velocity="10" lower="${-pi}" upper="${pi}"/>
                <dynamics damping="1.0" friction="1.0"/>
        </joint>



        <!-- PLIERS LINK AND JOINT -->

        <link name="first_pliers">
                <visual>
                        <geometry>
                                <box size="${pliers_length} ${pliers_width} ${pliers_height}" />
                        </geometry>
                        <origin xyz="0 0 ${pliers_height/2}" rpy="0 0 0"/>
                        <material name="magenta" />
                </visual>

                <collision>
                        <geometry>
                                <box size="${pliers_length} ${pliers_width} ${pliers_height}" />
                        </geometry>
                        <origin xyz="0 0 ${pliers_height/2}" rpy="0 0 0"/>
                        <material name="magenta" />
                </collision>

                <xacro:pliers_inertia/>
        </link>

        <joint name="first_pliers_joint" type="revolute">
                <parent link="second_moving_arm" />
                <child link="first_pliers" />
                <origin xyz="${arm_length} 0 ${3*arm_height/8}" rpy="0 ${pi/2} 0"/>
                <axis xyz="0 -1 0"/>
                <limit effort="5000" velocity="10" lower="0" upper="1.571"/>
                <dynamics damping="1.0" friction="1.0"/>
        </joint>


        <link name="second_pliers">
                <visual>
                        <geometry>
                                <box size="${pliers_length} ${pliers_width} ${pliers_height}" />
                        </geometry>
                        <origin xyz="0 0 ${pliers_height/2}" rpy="0 0 0"/>
                        <material name="magenta" />
                </visual>

                <collision>
                        <geometry>
                                <box size="${pliers_length} ${pliers_width} ${pliers_height}" />
                        </geometry>
                        <origin xyz="0 0 ${pliers_height/2}" rpy="0 0 0"/>
                        <material name="magenta" />
                </collision>

                <xacro:pliers_inertia/>
        </link>

        <joint name="second_pliers_joint" type="revolute">
                <parent link="second_moving_arm" />
                <child link="second_pliers" />
                <origin xyz="${-arm_length} 0 ${3*arm_height/8}" rpy="0 ${pi/2} 3.1415926535"/>
                <axis xyz="0 -1 0"/>
                <limit effort="5000" velocity="10" lower="0" upper="1.571"/>
                <dynamics damping="1.0" friction="1.0"/>
        </joint>



        <link name="third_pliers">
                <visual>
                        <geometry>
                                <box size="${mini_pliers_length} ${mini_pliers_width} ${mini_pliers_height}" />
                        </geometry>
                        <origin xyz="0 0 ${mini_pliers_height/2}" rpy="0 0 0"/>
                        <material name="cyan" />
                </visual>

                <collision>
                        <geometry>
                                <box size="${mini_pliers_length} ${mini_pliers_width} ${mini_pliers_height}" />
                        </geometry>
                        <origin xyz="0 0 ${mini_pliers_height/2}" rpy="0 0 0"/>
                        <material name="cyan" />
                </collision>

                <xacro:mini_pliers_inertia/>
        </link>

        <joint name="third_pliers_joint" type="revolute">
                <parent link="first_pliers" />
                <child link="third_pliers" />
                <origin xyz="${pliers_length/2} 0 ${pliers_height}" rpy="0 ${pi/16 + pi/2} ${pi}"/>
                <axis xyz="0 1 0"/>
                <limit effort="5000" velocity="10" lower="0" upper="1.571"/>
                <dynamics damping="1.0" friction="1000.0"/>
        </joint>



        <link name="fourth_pliers">
                <visual>
                        <geometry>
                                <box size="${mini_pliers_length} ${mini_pliers_width} ${mini_pliers_height}" />
                        </geometry>
                        <origin xyz="0 0 ${mini_pliers_height/2}" rpy="0 0 0"/>
                        <material name="cyan" />
                </visual>

                <collision>
                        <geometry>
                                <box size="${mini_pliers_length} ${mini_pliers_width} ${mini_pliers_height}" />
                        </geometry>
                        <origin xyz="0 0 ${mini_pliers_height/2}" rpy="0 0 0"/>
                        <material name="cyan" />
                </collision>

                <xacro:mini_pliers_inertia/>
        </link>

        <joint name="fourth_pliers_joint" type="revolute">
                <parent link="second_pliers" />
                <child link="fourth_pliers" />
                <origin xyz="${pliers_length/2} 0 ${pliers_height}" rpy="0 ${pi/16 + pi/2} ${pi}"/>
                <axis xyz="0 1 0"/>
                <limit effort="5000" velocity="10" lower="0" upper="1.571"/>
                <dynamics damping="1.0" friction="1000.0"/>
        </joint>




        <!-- LIDAR LINK AND JOINT-->

        <link name="lidar_link">
                <visual>
                        <origin xyz="${lidar_radius/2} ${lidar_radius/2} ${lidar_length/2}" rpy="0 0 0" />
                        <geometry>
                                <cylinder length="${lidar_length}" radius="${lidar_radius}" />
                        </geometry>
                </visual>
                <visual>
                        <origin xyz="${lidar_radius/2} ${lidar_radius/2} ${-lidar_length/2}" rpy="0 0 0" />
                        <geometry>
                                <box size="${arm_length/4} ${arm_width/4} ${arm_height/6}"/>
                        </geometry>
                </visual>

                <collision name="collision">
                        <origin xyz="${lidar_radius/2} ${lidar_radius/2} ${lidar_length/2}" rpy="0 0 0" />
                        <geometry>
                                <cylinder length="${lidar_length}" radius="${lidar_radius}" />
                        </geometry>
                        <gazebo>
                                <collide_bitmask>0x00</collide_bitmask>
                        </gazebo>
                </collision>

                <xacro:lidar_inertia />

        </link>

        <joint name="lidar_joint" type="fixed">
                <parent link="base_link" />
                <child link="lidar_link" />
                <origin xyz="${chassis_length/4} 0 ${chassis_offset + chassis_height}" rpy="0 0 0" />
        </joint>


        <!-- ROS2_CONTROL -->


        <ros2_control name="RobotController" type="system">
                <hardware>
                        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
                </hardware>

                <joint name="lf_joint">
                        <command_interface name="velocity"/>
                        <state_interface name="position"/>
                        <state_interface name="velocity"/>
                        <state_interface name="effort"/>
                </joint>

                <joint name="rf_joint">
                        <command_interface name="velocity"/>
                        <state_interface name="position"/>
                        <state_interface name="velocity"/>
                        <state_interface name="effort"/>
                </joint>

                <joint name="lb_joint">
                        <command_interface name="velocity"/>
                        <state_interface name="position"/>
                        <state_interface name="velocity"/>
                        <state_interface name="effort"/>
                </joint>

                <joint name="rb_joint">
                        <command_interface name="velocity"/>
                        <state_interface name="position"/>
                        <state_interface name="velocity"/>
                        <state_interface name="effort"/>
                </joint>


                <joint name="first_moving_arm_joint">
                        <command_interface name="position">
                                <param name="min">-3.1415926535</param>
                                <param name="max">3.1415926535</param>
                        </command_interface>
                        <state_interface name="position"/>
                        <state_interface name="velocity"/>
                        <state_interface name="effort"/>
                </joint>

                <joint name="second_moving_arm_joint">
                        <command_interface name="position">
                                <param name="min">-3.1415926535</param>
                                <param name="max">3.1415926535</param>
                        </command_interface>
                        <state_interface name="position"/>
                        <state_interface name="velocity"/>
                        <state_interface name="effort"/>
                </joint>

                <joint name="first_pliers_joint">
                        <command_interface name="position">
                                <param name="min">0</param>
                                <param name="max">1.571</param>
                        </command_interface>
                        <state_interface name="position"/>
                        <state_interface name="velocity"/>
                        <state_interface name="effort"/>
                </joint>

                <joint name="second_pliers_joint">
                        <command_interface name="position">
                                <param name="min">0</param>
                                <param name="max">1.571</param>
                        </command_interface>
                        <state_interface name="position"/>
                        <state_interface name="velocity"/>
                        <state_interface name="effort"/>
                </joint>

        </ros2_control>

</robot>
