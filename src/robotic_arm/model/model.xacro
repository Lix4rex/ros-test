<?xml version="1.0"?>
<robot name="simple_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

        <xacro:include filename="$(find robotic_arm)/model/gazebo.xacro" />
        <xacro:include filename="$(find robotic_arm)/model/parameters.xacro" />

        <link name="base_link">
                <visual>
                        <geometry>
                                <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
                        </geometry>
                        <origin xyz="0 0 0" rpy="0 0 0"/>
                        <material name="red"/>
                </visual>

                <collision>
                        <geometry>
                                <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
                        </geometry>
                        <origin xyz="0 0 0" rpy="0 0 0"/>
                        <material name="red"/>
                </collision>

                <xacro:chassis_inertia />
        </link>



        <link name="first_arm">
                <visual>
                        <geometry>
                                <box size="${arm_length} ${arm_width} ${arm_height}" />
                        </geometry>
                        <origin xyz="0 0 0" rpy="0 0 0" />
                        <material name="red" />
                </visual>

                <collision>
                        <geometry>
                                <box size="${arm_length} ${arm_width} ${arm_height}" />
                        </geometry>
                        <origin xyz="0 0 0" rpy="0 0 0" />
                        <material name="red"/>
                </collision>

                <xacro:arm_inertia />
        </link>

        <joint name="first_arm_joint" type="revolute">
                <parent link="base_link" />
                <child link="first_arm" />
                <origin xyz="0 0 ${arm_height/2}" rpy="0 0 0"/>
                <axis xyz="0 0 1"/>
                <limit effort="5000" velocity="10" lower="${-pi}" upper="${pi}"/>
                <dynamics damping="1.0" friction="1.0"/>
        </joint>



        <link name="second_arm">
                <visual>
                        <geometry>
                                <box size="${arm_length} ${arm_width} ${arm_height}" />
                        </geometry>
                        <origin xyz="0 0 ${arm_height/2}" rpy="0 0 0" />
                        <material name="green" />
                </visual>

                <collision>
                        <geometry>
                                <box size="${arm_length} ${arm_width} ${arm_height}" />
                        </geometry>
                        <origin xyz="0 0 ${arm_height/2}" rpy="0 0 0" />
                        <material name="green" />
                </collision>

                <xacro:arm_inertia />
        </link>

        <joint name="second_arm_joint" type="revolute">
                <parent link="first_arm" />
                <child link="second_arm" />
                <origin xyz="0 0 ${arm_height/2}" rpy="0 0 0"/>
                <axis xyz="1 0 0"/>
                <limit effort="5000" velocity="10" lower="${-pi/2}" upper="${pi/2}"/>
                <dynamics damping="1.0" friction="1.0"/>
        </joint>



        <link name="third_arm">
                <visual>
                        <geometry>
                                <box size="${arm_length} ${arm_width} ${arm_height}" />
                        </geometry>
                        <origin xyz="0 0 ${arm_height/2}" rpy="0 0 0" />
                        <material name="green" />
                </visual>

                <collision>
                        <geometry>
                                <box size="${arm_length} ${arm_width} ${arm_height}" />
                        </geometry>
                        <origin xyz="0 0 ${arm_height/2}" rpy="0 0 0" />
                        <material name="green" />
                </collision>

                <xacro:arm_inertia />
        </link>

        <joint name="third_arm_joint" type="revolute">
                <parent link="second_arm" />
                <child link="third_arm" />
                <origin xyz="0 0 ${arm_height}" rpy="0 0 0"/>
                <axis xyz="-1 0 0"/>
                <limit effort="5000" velocity="10" lower="${-pi}" upper="${pi/2}"/>
                <dynamics damping="1.0" friction="1.0"/>
        </joint>



        <link name="fourth_arm">
                <visual>
                        <geometry>
                                <box size="${arm_length} ${arm_width} ${arm_height}" />
                        </geometry>
                        <origin xyz="0 0 ${arm_height/2}" rpy="0 0 0" />
                        <material name="green" />
                </visual>

                <collision>
                        <geometry>
                                <box size="${arm_length} ${arm_width} ${arm_height}" />
                        </geometry>
                        <origin xyz="0 0 ${arm_height/2}" rpy="0 0 0" />
                        <material name="green" />
                </collision>

                <xacro:arm_inertia />
        </link>

        <joint name="fourth_arm_joint" type="revolute">
                <parent link="third_arm" />
                <child link="fourth_arm" />
                <origin xyz="0 0 ${arm_height}" rpy="0 0 0"/>
                <axis xyz="-1 0 0"/>
                <limit effort="5000" velocity="10" lower="${-pi/2}" upper="${pi/2}"/>
                <dynamics damping="1.0" friction="1.0"/>
        </joint>


        <!-- ROS2_CONTROL -->


        <ros2_control name="RobotController" type="system">
                <!--<hardware>
                        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
                </hardware> -->

                <hardware>
                        <plugin>robotic_arm_hardware/ArmHardwareInterface</plugin>
                </hardware>


                <!-- 1:[-pi;pi] 2:[-pi/2;pi/2] 3:[-pi;pi/2] 4:[-pi/2;pi/2] -->

                <joint name="first_arm_joint">
                        <command_interface name="position"/>
                        <state_interface name="position"/>
                </joint>

                <joint name="second_arm_joint">
                        <command_interface name="position"/>
                        <state_interface name="position"/>
                </joint>

                <joint name="third_arm_joint">
                        <command_interface name="position"/>
                        <state_interface name="position"/>
                </joint>

                <joint name="fourth_arm_joint">
                        <command_interface name="position"/>
                        <state_interface name="position"/>
                </joint>

        </ros2_control>

</robot>
