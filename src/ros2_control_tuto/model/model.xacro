<?xml version="1.0"?>
<robot name="simple_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find ros2_control_tuto)/model/parameters.xacro" />
<xacro:include filename="$(find ros2_control_tuto)/model/gazebo.xacro" />




<link name="world"></link>

<link name="first_link">
        <visual>
                <geometry>
                        <box size="${a} ${b} ${c}" />
                </geometry>
                <origin rpy="0 0 0" xyz="0 0 ${s}"/>
                <material name="red"/>
        </visual>

        <collision>
                <geometry>
                        <box size="${a} ${b} ${c}" />
                </geometry>
                <origin rpy="0 0 0" xyz="0 0 ${s}"/>
        </collision>

        <xacro:inertia_body />
</link>

<link name="second_link">
        <visual>
                <geometry>
                        <box size="${a} ${b} ${c}" />
                </geometry>
                <origin rpy="0 0 0" xyz="0 0 ${s}"/>
                <material name="blue"/>
        </visual>

        <collision>
                <geometry>
                        <box size="${a} ${b} ${c}" />
                </geometry>
                <origin rpy="0 0 0" xyz="0 0 ${s}"/>
        </collision>

        <xacro:inertia_body />
</link>


<link name="third_link">
        <visual>
                <geometry>
                        <box size="${a} ${b} ${c}"/>
                </geometry>
                <origin rpy="0 0 0" xyz="0 0 ${s}"/>
                <material name="green" />
        </visual>
        <collision>
                <geometry>
                        <box size="${a} ${b} ${c}"/>
                </geometry>
                <origin rpy="0 0 0" xyz="0 0 ${s}"/>
                <material name="green" />
        </collision>

        <xacro:inertia_body />
</link>



<joint name="fixed_joint" type="fixed">
        <parent link="world"/>
        <child link="first_link"/>
</joint>

<joint name="first_joint" type="revolute" >
        <parent link="first_link" />
        <child link="second_link" />
        <origin xyz="0 ${b} ${q}" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit effort="5000" velocity="10" lower="-1.571" upper="1.571"/>
        <dynamics damping="1.0" friction="1.0"/>
</joint>

<joint name="second_joint" type="continuous">
        <parent link="second_link" />
        <child link="third_link" />
        <origin xyz="0 ${b} ${q}" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit effort="5000" velocity="10"/>
        <dynamics damping="1.0" friction="1.0"/>
</joint>


<ros2_control name="RobotController" type="system">
        
        <hardware>
                <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>

        <joint name="first_joint">
                <command_interface name="position">
                        <param name="min">-1.571</param>
                        <param name="max">1.571</param>
                </command_interface>
                <state_interface name="position"/>
        </joint>
        
        <joint name="second_joint">
                <command_interface name="velocity">
                        <param name="min">-1.571</param>
                        <param name="max">1.571</param>
                </command_interface>
                <state_interface name="velocity"/>
                <state_interface name="position"/>
        </joint>

</ros2_control>

</robot>